htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDEs
.idea/
.vscode/
# Don't ignore the entire .vscode folder, but ignore user-specific settings
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json

# .NET / Visual Studio generated artifacts
**/bin/
**/obj/
*.suo
*.user
*.pdb
*.exe

# Secrets
/Shared/credentials.json
/Shared/service-account.json
/Shared/token*.json
*.env

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows reserved device name (not a real file)
nul

# Database assets: ignore image files, keep metadata tracked
Database/*.jpg
Database/*.jpeg
Database/*.png
Database/*.gif
Database/*.webp
Database/*.bmp
Database/*.tif
Database/*.tiff
Database/*.avif
Database/*.heic
!Database/*.efu
!Database/*.efu.*
