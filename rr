#!/usr/bin/env bash

# RealRendering Studio CLI Entrypoint (rr)
# This script routes commands to the appropriate Python tools.

# Dynamically determine the repository root based on this script's location
# This allows the script to work on D:/ (Desktop) or C:/ (Notebook) automatically.
REPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# If no arguments are provided, default to showing the help menu
if [ $# -eq 0 ]; then
    python "$REPO_DIR/tools/help_commands.py"
    exit 0
fi

# Capture the first argument as the command
COMMAND=$1
# Shift arguments so "$@" contains only the remaining arguments (e.g., the project code)
shift 

# Route the command
case "$COMMAND" in
    p)
        python "$REPO_DIR/tools/lookup.py" "$@"
        ;;
    dash)
        python "$REPO_DIR/scripts/generate_dashboard.py" --print-only "$@"
        ;;
    help)
        python "$REPO_DIR/tools/help_commands.py" "$@"
        ;;
    crm)
        python "$REPO_DIR/tools/view_crm.py" "$@"
        ;;
    open)
        # Get project code and find its F: drive path from the .md file
        PROJECT_CODE=${1^^} # Uppercase
        MD_FILE="$REPO_DIR/projects/$PROJECT_CODE.md"
        if [ -f "$MD_FILE" ]; then
            # Extract f_drive_path using grep/sed
            PATH_ON_F=$(grep "f_drive_path:" "$MD_FILE" | sed 's/f_drive_path: "\(.*\)"/\1/')
            if [ -n "$PATH_ON_F" ]; then
                echo -e "\033[92mOpening: $PATH_ON_F\033[0m"
                explorer.exe "$(echo $PATH_ON_F | sed 's/\//\\/g')"
            else
                echo -e "\033[91mF: drive path not found in $MD_FILE\033[0m"
            fi
        else
            echo -e "\033[91mProject $PROJECT_CODE not found.\033[0m"
        fi
        ;;
    c|copy)
        python "$REPO_DIR/tools/copy_data.py" "$@"
        ;;
    *)
        echo -e "\033[91mUnknown command: '$COMMAND'\033[0m"
        echo -e "Run 'rr help' to see available commands."
        exit 1
        ;;
esac
