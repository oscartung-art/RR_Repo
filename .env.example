# Local API key setup example (safe template)
# Do not commit real keys.

# Bash (current shell only)
export GEMINI_API_KEY="<your-gemini-api-key>"

# PowerShell (current shell only)
$env:GEMINI_API_KEY="<your-gemini-api-key>"

# PowerShell (persist for current user)
[Environment]::SetEnvironmentVariable("GEMINI_API_KEY", "<your-gemini-api-key>", "User")

# Gemini CLI
# gemini config set api-key <your-gemini-api-key>

# Navigate to your repo
cd /d/RR_Repo

# Run bridge script
python D:/RR_Repo/scripts/vibe_ipc_bridge.py